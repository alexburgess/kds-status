# Optional Dashboard / Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Local JSON definitions
# Leave unset to use apps/dashboard/.local-data/device-definitions.json.
KDS_DEFINITIONS_PATH=

# Shared internal secret sent by the baked-in Android app.
# The default must match AppConfigParser.DEFAULT_DEVICE_SECRET in the Android app.
KDS_DEVICE_SHARED_SECRET=kds-status-internal-v1

# Play Store version lookup
PLAY_STORE_COUNTRY=us
PLAY_STORE_LANGUAGE=en
PLAY_STORE_LOOKUP_TIMEOUT_MS=5000
